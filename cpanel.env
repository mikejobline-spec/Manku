# -----------------------------------------------------------------------------
# Mankusa Printing Press - cPanel Environment File
# Save this file as ".env" in your application root folder on cPanel
# -----------------------------------------------------------------------------

# cPanel SMTP Configuration
SMTP_HOST="mail.mankusaprinting.com"
SMTP_PORT=465
SMTP_USER="quotes@mankusaprinting.com"
SMTP_SECURE="true"
SMTP_FROM="quotes@mankusaprinting.com"
SMTP_TO="quotes@mankusaprinting.com"

# IMPORTANT: Replace the placeholder below with your real cPanel email password
SMTP_PASS="YOUR_CPANEL_PASSWORD_HERE"
